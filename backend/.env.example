# 后端服务端口
PORT=3000

# 运行环境
NODE_ENV=development

# MongoDB 连接字符串
# 本地开发（无认证）：
MONGODB_URI=mongodb://localhost:27017/permission_manager

# 生产环境（带认证）：
# MONGODB_URI=mongodb://username:password@localhost:27017/permission_manager?authSource=admin

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET=permission-manager-jwt-secret-key-2024

# JWT 过期时间
JWT_EXPIRES_IN=24h

# 日志级别
LOG_LEVEL=info
